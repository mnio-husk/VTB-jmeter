        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import groovy.json.JsonOutput
import java.util.Random
import java.util.UUID

def rand = new Random()

// 1. UUID msg_id
def msgId = UUID.randomUUID().toString()

// 2. ФИО по роду
def isMale = rand.nextBoolean()
def maleNames = [&quot;Василий&quot;, &quot;Геннадий&quot;, &quot;Александр&quot;]
def femaleNames = [&quot;Мария&quot;, &quot;Анна&quot;, &quot;Елена&quot;]
def malePatr = [&quot;Геннадьевич&quot;, &quot;Александрович&quot;]
def femalePatr = [&quot;Николаевна&quot;, &quot;Александровна&quot;]
def surnamesMale = [&quot;Закроев&quot;, &quot;Иванов&quot;]
def surnamesFemale = [&quot;Закроева&quot;, &quot;Иванова&quot;]

def name = isMale ? maleNames[rand.nextInt(maleNames.size())] 
                  : femaleNames[rand.nextInt(femaleNames.size())]
def patr = isMale ? malePatr[rand.nextInt(malePatr.size())] 
                  : femalePatr[rand.nextInt(femalePatr.size())]
def surname = isMale ? surnamesMale[rand.nextInt(surnamesMale.size())] 
                     : surnamesFemale[rand.nextInt(surnamesFemale.size())]
def fullName = surname + &quot; &quot; + name + &quot; &quot; + patr

// 3. ИНН
def inn = &quot;77&quot; + String.format(&quot;%9d&quot;, rand.nextLong(100000000L, 999999999L))

// 4. JSON с РУССКИМ ТЕКСТОМ (JsonOutput.prettyPrint)
def jsonData = [
    msg_id: msgId,
    full_name: fullName,
    inn: inn
]

def json = JsonOutput.toJson(jsonData)  // ✅ Читаемый русский текст!

vars.put(&quot;vtbJson&quot;, json)
vars.put(&quot;msgId&quot;, msgId)
vars.put(&quot;fullName&quot;, fullName)
vars.put(&quot;inn&quot;, inn)

log.info(&quot;VTB: ${msgId} | ${fullName} | ${inn}&quot;)
</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223PreProcessor>
